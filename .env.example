# Copy this file to `.env`. For the default offline stack you DON'T need a key.
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# This dive is about WHAT GOES IN THE WINDOW — which is provider-neutral. The
# default `mock` stack is a deterministic, offline "model" that only knows what's
# in the messages you give it, so the whole repo runs with no key and no cost.
#
#   mock    -> offline, deterministic, no key   (the default)
#   openai  -> OpenAI chat                       (needs OPENAI_API_KEY)
#   claude  -> Claude messages                   (needs ANTHROPIC_API_KEY)
#
# Everything runs on the mock. A key is optional — it's mainly useful for the
# context-rot demo (example 07), where a real model shows a subtler version of the
# quality degradation the mock demonstrates deterministically.
# ---------------------------------------------------------------------------
PROVIDER=mock

# --- API keys (optional) are NOT stored here ---
# The default mock needs no key. To use a real provider, store its key in your OS
# keychain and inject it per-command with `secrun` (setup: ../SECRETS.md), then run
# key-using scripts as:  secrun python examples/...
#   PROVIDER=openai  needs  OPENAI_API_KEY     https://platform.openai.com/api-keys
#   PROVIDER=claude  needs  ANTHROPIC_API_KEY  https://console.anthropic.com/settings/keys
